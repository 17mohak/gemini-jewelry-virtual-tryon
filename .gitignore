# Environment / secrets
.env
*.env.local

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.coverage
htmlcov/

# User-generated content (kept out of git; folders preserved via .gitkeep)
backend/uploads/*
!backend/uploads/.gitkeep
backend/outputs/*
!backend/outputs/.gitkeep

# Local image-sourcing workspace (candidates reviewed by hand, not shipped)
scripts/_candidates/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
backend/server.*.log

# Evaluation run outputs (regenerable, may contain large images)
eval/runs/
eval/compositing/
# Stress assets: reference garments are user-sourced (see eval/stress/refs/README.md),
# run outputs and scratch are regenerable.
eval/stress/refs/*
!eval/stress/refs/.gitkeep
!eval/stress/refs/README.md
eval/stress/runs/
eval/stress/out/
eval/stress/_*
eval/stress/*.log

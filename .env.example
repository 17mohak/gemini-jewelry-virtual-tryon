# ── Nano Banana (image try-on) ────────────────────────────────────────────────
# Nano Banana is Google's image-editing model family.
# Get a key from Google AI Studio: https://aistudio.google.com/apikey
# Both standard AI Studio keys ("AIza...") and Vertex Express keys ("AQ. ...")
# work with the endpoint this app uses.
NANOBANANA_API_KEY=your_nanobanana_api_key_here

# Optional: override the image model. Default is gemini-3.1-flash-image;
# the older gemini-2.5-flash-image refuses some clothing edits on real photos.
# NANOBANANA_MODEL=gemini-3.1-flash-image

# ── LTX 2.3 (image -> short video) ────────────────────────────────────────────
# Get a key from the LTX API console: https://ltx.io/model/api
# Keys look like "ltxv_...". Billed per second of generated video
# (ltx-2-3-fast: $0.06/s at 1080p; the 6 s minimum clip costs ~$0.36).
LTX_API_KEY=your_ltx_api_key_here

# Optional overrides
# LTX_MODEL=ltx-2-3-fast
# LTX_API_BASE=https://api.ltx.video
# LTX_VIDEO_DURATION=6

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=local

# ── Google Gemini (image try-on) ─────────────────────────────────────────────
# Get a free key from Google AI Studio: https://aistudio.google.com/apikey
# Standard AI Studio keys start with "AIza...".
# Vertex AI Express-mode keys (start with "AQ.") are also supported and
# auto-detected.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the image model (default: gemini-2.5-flash-image)
# GEMINI_MODEL=gemini-2.5-flash-image

# ── Kling (image -> short video) ──────────────────────────────────────────────
# Get free trial keys from https://app.klingai.com / Kling AI developer console.
# Kling uses an AccessKey + SecretKey pair (the app signs a JWT from them).
KLING_ACCESS_KEY=your_kling_access_key_here
KLING_SECRET_KEY=your_kling_secret_key_here

# Optional: override Kling model / API base / video length (seconds: 5 or 10)
# KLING_MODEL=kling-v1-6
# KLING_API_BASE=https://api-singapore.klingai.com
# KLING_VIDEO_DURATION=5

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=local
# HOST=127.0.0.1
# PORT=8000
